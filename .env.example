# JWT Configuration
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-change-this-in-production

# Vercel KV (Redis) - Auto-populated by Vercel when you create a KV database
# Leave these empty - Vercel will fill them automatically
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Email Service (Optional - for future email verification)
# SENDGRID_API_KEY=
# FROM_EMAIL=noreply@theluxine.com
